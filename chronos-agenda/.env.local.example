# Configurações de desenvolvimento local
# Copie este arquivo para .env.local e ajuste conforme necessário

# ConnectionString para PostgreSQL
# Padrão: PostgreSQL em localhost:5432 com usuário postgres
ConnectionStrings__ChronosAgenda=Host=localhost;Port=5432;Database=chronos_agenda;Username=postgres;Password=postgres

# Se estiver usando Docker Compose ou outra configuração, ajuste conforme necessário
# Exemplo com Docker:
# ConnectionStrings__ChronosAgenda=Host=chronos-db;Port=5432;Database=chronos_agenda;Username=postgres;Password=postgres
